meta {
  name: Driver Login
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/api/v1/users/login/
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "{{driverEmail}}",
    "password": "{{driverPassword}}"
  }
}

script:post-response {
  if (res.status === 200 && res.body?.access) {
    bru.setEnvVar("driverAccessToken", res.body.access);
  }
}
